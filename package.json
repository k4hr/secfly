{
  "name": "secfly",
  "version": "0.1.0",
  "private": true,
  "description": "Каркас платформы SecFly для безопасного виртуального моделирования",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.21"
    }
  },
  "scripts": {
    "dev": "corepack pnpm --parallel --filter './apps/*' dev",
    "build": "corepack pnpm -r --if-present build",
    "clean": "node scripts/clean.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "corepack pnpm --filter \"./packages/**\" build && corepack pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "architecture:check": "node scripts/check-architecture.mjs",
    "security:check": "node scripts/check-secrets.mjs",
    "check": "corepack pnpm format:check && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm architecture:check && corepack pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
